# MySQL Database Configuration
# For Docker: Use these default values (already set in docker-compose.yml)
# For external MySQL: Replace with your actual credentials
DB_NAME=capstone_db
DB_USER=capstone_user
DB_PASSWORD=capstone_pass
DB_HOST=db
DB_PORT=3306

# Django Secret Key (change for production!)
SECRET_KEY=django-insecure-rpamq73a+@!0ee+00f9+r@i)!$+sp(j2+_i#pd^(%lb)w2rc=-

# --- LLM Service Configuration ---
# Choose your preferred provider: 'ollama' (default), 'gemini', or 'azure'
LLM_PROVIDER=

# 1. Ollama (Local/Express Service)
# OLLAMA_SERVICE_URL=http://localhost:3001/api/query
# OLLAMA_API_KEY=dev_secret_key
# OLLAMA_MODEL=mistral:latest

# 2. Google Gemini
# GEMINI_API_KEY=your_gemini_key_here
# GEMINI_MODEL=gemini-2.5-flash

# 3. Azure OpenAI
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_azure_key_here
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
# AZURE_OPENAI_DEPLOYMENT=gpt-5-nano
